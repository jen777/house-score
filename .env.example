# Copy to .env for local dev. In Coolify, set these as Environment Variables.

# --- Database ---
# For local `npm run dev` against the compose Postgres, expose a host port or
# point this at your local Postgres. In compose, DATABASE_URL is built from the
# POSTGRES_* values below and points at the `db` service.
DATABASE_URL=postgres://housescore:housescore@localhost:5432/housescore
POSTGRES_USER=housescore
POSTGRES_PASSWORD=housescore
POSTGRES_DB=housescore

# --- Auth (single-user password gate) ---
APP_PASSWORD=changeme
# Use a long random string, e.g. `openssl rand -hex 32`
AUTH_SECRET=please-change-this-to-a-long-random-string

# --- AI extraction (Claude) ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Maps (Google) ---
# Browser map (Maps JavaScript API). Exposed to the client, so restrict it by
# HTTP referrer in the Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side geocoding (Geocoding API). Kept private; restrict by IP. If unset,
# geocoding falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY. Both are optional —
# without them, houses save fine but won't appear on the map.
GOOGLE_MAPS_API_KEY=

# --- Property-data enrichment (Phase 2: RentCast) ---
# Server-side only; enables the "Enrich from RentCast" action. Leave blank to
# disable enrichment (the button is hidden/disabled).
RENTCAST_API_KEY=
# Optional override; defaults to https://api.rentcast.io/v1
RENTCAST_BASE_URL=https://api.rentcast.io/v1
